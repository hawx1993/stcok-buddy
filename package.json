{
  "name": "stockbuddy-desktop",
  "version": "0.3.2",
  "description": "StockBuddy - 对话式 A 股投研助手 Electron 桌面应用",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.node.json --watch --preserveWatchOutput & wait-on dist-electron/electron/main.js && electron .",
    "build:icon": "mkdir -p build/icon.iconset /tmp/stocksense-icon && qlmanage -t -s 1024 -o /tmp/stocksense-icon public/icons/icon.svg >/dev/null 2>&1 && ICON=/tmp/stocksense-icon/icon.svg.png && sips -z 16 16 $ICON --out build/icon.iconset/icon_16x16.png >/dev/null && sips -z 32 32 $ICON --out build/icon.iconset/icon_16x16@2x.png >/dev/null && sips -z 32 32 $ICON --out build/icon.iconset/icon_32x32.png >/dev/null && sips -z 64 64 $ICON --out build/icon.iconset/icon_32x32@2x.png >/dev/null && sips -z 128 128 $ICON --out build/icon.iconset/icon_128x128.png >/dev/null && sips -z 256 256 $ICON --out build/icon.iconset/icon_128x128@2x.png >/dev/null && sips -z 256 256 $ICON --out build/icon.iconset/icon_256x256.png >/dev/null && sips -z 512 512 $ICON --out build/icon.iconset/icon_256x256@2x.png >/dev/null && sips -z 512 512 $ICON --out build/icon.iconset/icon_512x512.png >/dev/null && cp $ICON build/icon.iconset/icon_512x512@2x.png && iconutil -c icns build/icon.iconset -o build/icon.icns",
    "build": "node scripts/write-build-info.cjs && npm run typecheck && vite build && tsc -p tsconfig.node.json && cp electron/preload.cjs dist-electron/electron/preload.cjs",
    "build:pwa": "npm run build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac dmg --arm64",
    "dist:all": "npm run build && electron-builder --mac dmg --arm64 && electron-builder --win nsis --x64",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "selfcheck:market-data": "tsc -p tsconfig.node.json && electron dist-electron/electron/services/market-data/market-data.selfcheck.js"
  },
  "keywords": [
    "electron",
    "stock",
    "ai-agent",
    "a share",
    "a stock agent",
    "stock agent",
    "stock buddy",
    "stock buddy desktop"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.stocksense.desktop",
    "productName": "StockBuddy",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/icons/icon.svg",
        "to": "icons/icon.svg"
      },
      {
        "from": "build/commit-hash.txt",
        "to": "commit-hash.txt"
      },
      {
        "from": "build/telemetry.json",
        "to": "telemetry.json"
      },
      {
        "from": "public/store",
        "to": "public/store"
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "StockBuddy-${version}-${arch}-setup.${ext}"
    },
    "dmg": {
      "artifactName": "StockBuddy-${version}-${arch}.dmg",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@klinecharts/pro": "0.1.1",
    "@langchain/core": "^1.2.1",
    "@langchain/openai": "^1.5.3",
    "ai": "^7.0.15",
    "antd": "^6.5.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "electron-store": "^10.0.1",
    "gsap": "^3.12.5",
    "klinecharts": "10.0.0-beta3",
    "langchain": "^1.5.2",
    "lucide-react": "^0.469.0",
    "marked": "^13.0.3",
    "posthog-js": "^1.404.0",
    "posthog-node": "^5.45.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stock-sdk": "^2.4.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wait-on": "^8.0.1"
  }
}
